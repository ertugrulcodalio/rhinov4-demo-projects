{
  "info": {
    "name": "blog-feature-v4",
    "description": "Blog feature API — Rails 8.1.3 + Rhino v4. Base URL: http://localhost:3012\n\n**Seed credentials:**\n- alice@acme.com / password (admin @ Acme Corp)\n- bob@acme.com / password (manager)\n- carol@acme.com / password (member)\n\n**Quick start:**\n1. Run \"Login\" → token saved automatically to `auth_token` variable\n2. `org_id` is pre-set to `acme-corp` (the seed org slug)\n3. Use any Blog request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3012", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "org_id", "value": "acme-corp", "type": "string" },
    { "key": "blog_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('auth_token', json.token);",
                  "  console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/api/auth/login",
            "description": "Login and get access token. Token is saved automatically to `auth_token` variable."
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"name\": \"New User\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Organizations",
      "item": [
        {
          "name": "Get My Organizations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "var orgs = json.results || json.data || [];",
                  "if (orgs.length > 0) {",
                  "  var slug = orgs[0].slug || orgs[0].id;",
                  "  pm.collectionVariables.set('org_id', slug);",
                  "  console.log('org_id set to:', slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/organizations",
            "description": "List organizations. First org ID is saved to `org_id` variable automatically."
          }
        }
      ]
    },
    {
      "name": "Blogs",
      "item": [
        {
          "name": "List Blogs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{org_id}}/blogs",
              "host": ["{{base_url}}"],
              "path": ["api", "{{org_id}}", "blogs"],
              "query": [
                { "key": "page", "value": "1", "disabled": true },
                { "key": "limit", "value": "10", "disabled": true },
                { "key": "filter[title_cont]", "value": "", "disabled": true },
                { "key": "filter[published_eq]", "value": "true", "disabled": true },
                { "key": "sort", "value": "created_at", "disabled": true }
              ]
            },
            "description": "List all blogs for the organization. Supports pagination, filtering by title/published, and sorting."
          }
        },
        {
          "name": "Get Blog",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/blogs/{{blog_id}}",
            "description": "Get a single blog by ID."
          }
        },
        {
          "name": "Create Blog",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('blog_id', json.id);",
                  "  console.log('blog_id set to:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Blog Post\",\n  \"body\": \"This is the body of the blog post.\",\n  \"published\": false\n}"
            },
            "url": "{{base_url}}/api/{{org_id}}/blogs",
            "description": "Create a new blog. Requires admin role. Saves new blog ID to `blog_id` variable."
          }
        },
        {
          "name": "Update Blog",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Blog Title\",\n  \"body\": \"Updated body content.\",\n  \"published\": true\n}"
            },
            "url": "{{base_url}}/api/{{org_id}}/blogs/{{blog_id}}",
            "description": "Update an existing blog. Requires admin role."
          }
        },
        {
          "name": "Delete Blog (Soft)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/blogs/{{blog_id}}",
            "description": "Soft-delete a blog (uses Discard gem — blog is hidden but not removed from DB)."
          }
        },
        {
          "name": "List Trashed Blogs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/blogs/trashed",
            "description": "List soft-deleted blogs."
          }
        },
        {
          "name": "Restore Blog",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/blogs/{{blog_id}}/restore",
            "description": "Restore a soft-deleted blog."
          }
        },
        {
          "name": "Force Delete Blog",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{base_url}}/api/{{org_id}}/blogs/{{blog_id}}/force-delete",
            "description": "Permanently delete a blog from the database."
          }
        }
      ]
    }
  ]
}
